<Window x:Class="ReTex.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReTex.App.ViewModels"
        xmlns:conv="clr-namespace:ReTex.App.Converters"
        Title="ReTex Settings" Height="420" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#111827">

    <Window.Resources>
        <conv:BoolToStatusBrushConverter x:Key="OkToBrush"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D1D5DB"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="Status" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Some required folders or tools weren't detected. Point ReTex to the right locations below."
                   TextWrapping="Wrap" Margin="0,0,0,14" FontWeight="SemiBold"
                   Visibility="{Binding IntroVisible, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Width="90" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Save" Width="90" Margin="8,0,0,0" IsDefault="True" Click="Save_Click"/>
        </StackPanel>

        <StackPanel>
            <!-- Workshop / mods folder -->
            <TextBlock Text="Arma 3 Workshop / mods folder" FontWeight="Bold"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="The folder containing your @-mod subfolders, e.g. ...\Arma 3\!Workshop"/>
            <DockPanel Margin="0,6,0,0">
                <Button DockPanel.Dock="Right" Content="Browse…" Width="80" Margin="8,0,0,0"
                        Command="{Binding BrowseWorkshopCommand}"/>
                <TextBox Text="{Binding WorkshopPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
            </DockPanel>
            <TextBlock Style="{StaticResource Status}" Text="{Binding WorkshopStatus}"
                       Foreground="{Binding WorkshopOk, Converter={StaticResource OkToBrush}}"/>

            <Separator Margin="0,14" Background="#374151"/>

            <!-- Projects root -->
            <TextBlock Text="Projects folder" FontWeight="Bold"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="Where ReTex stores your retexture projects (created automatically if missing)."/>
            <DockPanel Margin="0,6,0,0">
                <Button DockPanel.Dock="Right" Content="Browse…" Width="80" Margin="8,0,0,0"
                        Command="{Binding BrowseProjectsRootCommand}"/>
                <TextBox Text="{Binding ProjectsRoot, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
            </DockPanel>
            <TextBlock Style="{StaticResource Status}" Text="{Binding ProjectsRootStatus}"
                       Foreground="{Binding ProjectsRootOk, Converter={StaticResource OkToBrush}}"/>

            <Separator Margin="0,14" Background="#374151"/>

            <!-- pboc.exe -->
            <TextBlock Text="pboc.exe (PBO Manager CLI)" FontWeight="Bold"/>
            <TextBlock Style="{StaticResource Hint}"
                       Text="Only needed for the &quot;Pack @Mod&quot; step. Leave blank to auto-detect the PBO Manager install."/>
            <DockPanel Margin="0,6,0,0">
                <Button DockPanel.Dock="Right" Content="Browse…" Width="80" Margin="8,0,0,0"
                        Command="{Binding BrowsePbocCommand}"/>
                <Button DockPanel.Dock="Right" Content="Auto" Width="56" Margin="8,0,0,0"
                        Command="{Binding AutoDetectPbocCommand}" ToolTip="Clear override and auto-detect"/>
                <TextBox Text="{Binding PbocPath, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
            </DockPanel>
            <TextBlock Style="{StaticResource Status}" Text="{Binding PbocStatus}"
                       Foreground="{Binding PbocOk, Converter={StaticResource OkToBrush}}"/>
        </StackPanel>
    </DockPanel>
</Window>
