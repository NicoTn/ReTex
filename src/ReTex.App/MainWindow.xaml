<Window x:Class="ReTex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReTex.App.ViewModels"
        xmlns:local="clr-namespace:ReTex.App"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:h="http://helix-toolkit.org/wpf"
        Title="ReTex - Arma 3 Retexture Studio"
        Icon="app.ico"
        Height="840" Width="1400" MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        Background="{StaticResource Bg.Window}" Foreground="{StaticResource Fg.Primary}"
        TextOptions.TextFormattingMode="Ideal">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Keyboard shortcuts mapped to existing commands. -->
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveConfigCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding RegenerateConfigCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="P" Modifiers="Ctrl+Shift" Command="{Binding PackCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ScanWorkshopCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="8" Background="{StaticResource Bg.Toolbar}">
            <DockPanel>
                <TextBlock Text="Mod folder:" Foreground="{StaticResource Fg.Primary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Right" Content="About" Width="64" Margin="8,0,0,0"
                        Command="{Binding ShowAboutCommand}"/>
                <Button DockPanel.Dock="Right" Content="Settings…" Width="80" Margin="8,0,0,0"
                        Command="{Binding OpenSettingsCommand}"/>
                <!-- pboc availability indicator (green = ready, amber = missing) -->
                <Border DockPanel.Dock="Right" Margin="8,0,0,0" Padding="8,0" CornerRadius="3"
                        Background="{StaticResource Bg.Panel}" VerticalAlignment="Stretch"
                        ToolTip="{Binding PbocTooltip}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="●" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource Accent.Error}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PbocReady}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Accent.Ok}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="pboc" Foreground="{StaticResource Fg.Status}" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Button DockPanel.Dock="Right" Content="Scan" Width="80" Margin="8,0,0,0"
                        Command="{Binding ScanWorkshopCommand}" ToolTip="Rescan the mod folder (F5)"/>
                <TextBox Text="{Binding WorkshopPath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Project bar: current project + New / Open / Recent, always visible (document-bar style) -->
        <Border DockPanel.Dock="Top" Padding="8,5" Background="{StaticResource Bg.Status}"
                BorderBrush="{StaticResource Border.Muted}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Project" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <ComboBox DockPanel.Dock="Right" Width="120" VerticalAlignment="Center"
                          ItemsSource="{Binding RecentProjects}" SelectedItem="{Binding SelectedRecent, Mode=TwoWay}"
                          ToolTip="Open a recent project">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ProjectPathToName}}" ToolTip="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock DockPanel.Dock="Right" Text="Recent" VerticalAlignment="Center"
                           Foreground="{StaticResource Fg.Muted}" Margin="14,0,6,0"/>
                <Button DockPanel.Dock="Right" Content="Open…" Width="64" Margin="6,0,0,0"
                        Command="{Binding OpenProjectCommand}" ToolTip="Open a project (Ctrl+O)"/>
                <Button DockPanel.Dock="Right" Content="New" Width="56" Margin="14,0,0,0"
                        Command="{Binding NewProjectCommand}" ToolTip="Create a new project (Ctrl+N)"/>
                <TextBox DockPanel.Dock="Right" Width="170" VerticalContentAlignment="Center" Margin="6,0,0,0"
                         Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Name used when creating a new project"/>
                <TextBlock DockPanel.Dock="Right" Text="New name:" VerticalAlignment="Center"
                           Foreground="{StaticResource Fg.Muted}" Margin="14,0,6,0"/>
                <!-- Fills the middle: which project is currently loaded -->
                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"
                           Text="{Binding CurrentProjectName, StringFormat=Loaded: {0}}"
                           ToolTip="{Binding CurrentProjectPath}"/>
            </DockPanel>
        </Border>

        <!-- Status bar (severity-coloured, wraps so warnings are fully readable) -->
        <Border DockPanel.Dock="Bottom" Padding="8,4" Background="{StaticResource Bg.Status}">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" MaxHeight="48"
                       Foreground="{Binding StatusSeverity, Converter={StaticResource StatusSeverityToBrush}}"/>
        </Border>

        <!-- Main area: browsing + preview on top, config editor in its own full-width row below.
             Star sizing (+ a draggable horizontal splitter) lets both rows grow on larger screens. -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="BrowseRow" Height="3*" MinHeight="300"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*" MinHeight="160"/>
            </Grid.RowDefinitions>

            <!-- ROW 0: Mods | Assets | Detail + preview + project controls -->
            <Grid Grid.Row="0">
                <!-- Proportional (star) widths so every column grows with the window instead of only
                     the preview. Splitters still let the user rebalance; MinWidth keeps them usable. -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.3*" MinWidth="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2.2*" MinWidth="360"/>
                </Grid.ColumnDefinitions>

                <!-- Mods -->
                <DockPanel Grid.Column="0" Margin="6">
                    <TextBlock DockPanel.Dock="Top" Text="Mods" Style="{StaticResource Heading}" Margin="2,2,2,6"/>
                    <TextBox DockPanel.Dock="Top" Margin="0,0,0,6" VerticalContentAlignment="Center"
                             Text="{Binding ModSearch, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Filter mods by name"/>
                    <ListBox ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                             DisplayMemberPath="DisplayName" HorizontalContentAlignment="Stretch"/>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="4" VerticalAlignment="Stretch"/>

                <!-- Assets -->
                <DockPanel Grid.Column="2" Margin="6">
                    <TextBlock DockPanel.Dock="Top" Text="Retexturable assets" Style="{StaticResource Heading}" Margin="2,2,2,6"/>
                    <ComboBox DockPanel.Dock="Top" Margin="0,0,0,6" ItemsSource="{Binding PboNames}"
                              SelectedItem="{Binding PboFilter}" ToolTip="Filter by PBO (sub-mod)"/>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <ComboBox Width="110" ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding CategoryFilter}"/>
                        <TextBox Margin="6,0,0,0" VerticalContentAlignment="Center"
                                 Text="{Binding AssetSearch, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Assets}" SelectedItem="{Binding SelectedAsset}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource Bg.Chip}" CornerRadius="3" Padding="4,0" Margin="0,1,6,1">
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource Fg.Primary}" FontSize="10"/>
                                        </Border>
                                        <TextBlock Text="{Binding ClassName}" Foreground="{StaticResource Fg.Muted}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Column="3" Width="4" VerticalAlignment="Stretch"/>

                <!-- Detail (top) + preview (grows) + project controls. The retextures list moved to the
                     bottom row (beside config.cpp) so it gets real height on small screens. -->
                <Grid Grid.Column="4" Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Asset detail -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource Border.Muted}" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,8">
                        <StackPanel DataContext="{Binding SelectedAsset}">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="View source config.cpp" Padding="8,3" VerticalAlignment="Top"
                                        IsEnabled="{Binding Converter={StaticResource NotNullToBool}}"
                                        Command="{Binding DataContext.OpenSourceConfigCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="De-rapify the source mod's config.bin and open it as a read-only reference"/>
                                <TextBlock Text="{Binding Label}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Model}" Foreground="{StaticResource Fg.Muted}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Selections to retexture:" Margin="0,6,0,0" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding DataContext.AssetSelections, RelativeSource={RelativeSource AncestorType=Window}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Label}" IsChecked="{Binding Selected}" Foreground="{StaticResource Fg.Primary}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding HiddenSelectionsTextures}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding}" Foreground="{StaticResource Fg.Muted}" FontSize="11" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Preview: flat texture + 3D model tabs (grows with the window) -->
                    <TabControl x:Name="PreviewTabs" Grid.Row="1" Margin="0,0,0,8" Background="{StaticResource Bg.Panel}"
                                BorderBrush="{StaticResource Border.Muted}" BorderThickness="1">
                        <TabItem Header="Texture">
                            <Grid Background="{StaticResource Bg.Panel}">
                                <!-- Zoom/pan viewport: mouse-wheel zooms about the cursor, left-drag pans,
                                     double-click resets. Clipped so a zoomed texture stays inside the panel. -->
                                <Border x:Name="TexturePreviewViewport" ClipToBounds="True" Background="Transparent"
                                        MouseWheel="TexturePreview_MouseWheel"
                                        MouseLeftButtonDown="TexturePreview_MouseLeftButtonDown"
                                        MouseLeftButtonUp="TexturePreview_MouseLeftButtonUp"
                                        MouseMove="TexturePreview_MouseMove"
                                        MouseRightButtonDown="TexturePreview_Reset"
                                        Cursor="SizeAll">
                                    <!-- Image + pick marker share one transform so the marker stays glued to its
                                         texel while zooming/panning. Ctrl+click on the 3D model sets the marker. -->
                                    <Grid RenderTransformOrigin="0,0">
                                        <Grid.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="TextureScale"/>
                                                <TranslateTransform x:Name="TextureTranslate"/>
                                            </TransformGroup>
                                        </Grid.RenderTransform>
                                        <Image x:Name="TexturePreviewImage" Source="{Binding PreviewImage}" Stretch="Uniform" Margin="4"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <Canvas x:Name="PickMarkerCanvas" Margin="4" IsHitTestVisible="False">
                                            <Path x:Name="PickMarker" Visibility="Collapsed" Width="18" Height="18"
                                                  Stroke="#FF29B6F6" StrokeThickness="1.5" Fill="#5029B6F6">
                                                <Path.Data>
                                                    <GeometryGroup>
                                                        <EllipseGeometry Center="9,9" RadiusX="8" RadiusY="8"/>
                                                        <LineGeometry StartPoint="9,0" EndPoint="9,18"/>
                                                        <LineGeometry StartPoint="0,9" EndPoint="18,9"/>
                                                    </GeometryGroup>
                                                </Path.Data>
                                            </Path>
                                        </Canvas>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding PreviewInfo}" Foreground="{StaticResource Fg.Muted}" FontSize="10"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="6,0,0,4"/>
                                <TextBlock Text="Ctrl+click the texture to find it on the model" Foreground="#FF29B6F6" FontSize="10"
                                           IsHitTestVisible="False" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,6,4"/>
                                <!-- Result of a 3D→texture pick (Ctrl+click on the model): the marked spot's UV + pixel. -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6" Padding="7,4" CornerRadius="3"
                                        Background="#D0111827" BorderBrush="#FF29B6F6" BorderThickness="1" IsHitTestVisible="False"
                                        Visibility="{Binding PickInfo, Converter={StaticResource NonEmptyToVisibility}}">
                                    <TextBlock Text="{Binding PickInfo}" Foreground="{StaticResource Fg.Primary}" FontSize="11"/>
                                </Border>

                                <!-- Prev / next through the asset's (or retexture's) multiple selection textures -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,6"
                                            Visibility="{Binding PreviewCounter, Converter={StaticResource NonEmptyToVisibility}}">
                                    <Button Content="◀" Width="26" Padding="0,1" Command="{Binding PreviewPrevCommand}"
                                            ToolTip="Previous selection texture"/>
                                    <Border Background="#D0111827" CornerRadius="3" Padding="8,2" Margin="6,0">
                                        <TextBlock Text="{Binding PreviewCounter}" Foreground="{StaticResource Fg.Primary}" FontSize="11" VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Content="▶" Width="26" Padding="0,1" Command="{Binding PreviewNextCommand}"
                                            ToolTip="Next selection texture"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,4,4,0">
                                    <Button Content="✎ Edit source" Padding="8,2" Command="{Binding OpenSourceTexturesCommand}"
                                            ToolTip="Open the source texture(s) in your image editor (temp copies) to reference or grab parts"/>
                                    <Button Content="⟳ Refresh" Padding="8,2" Margin="6,0,0,0" Command="{Binding RefreshPreviewCommand}"
                                            ToolTip="Reload the preview after editing the texture externally"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                        <TabItem Header="3D Model">
                            <Grid Background="{StaticResource Bg.Panel}">
                                <h:HelixViewport3D x:Name="Viewport" Background="{StaticResource Bg.Panel}"
                                                   ShowCoordinateSystem="False" ShowViewCube="True"
                                                   ZoomExtentsWhenLoaded="True" IsHeadLightEnabled="True">
                                    <ModelVisual3D Content="{Binding PreviewModel3D}"/>
                                    <ModelVisual3D Content="{Binding HighlightModel3D}"/>
                                </h:HelixViewport3D>
                                <TextBlock Foreground="{StaticResource Fg.Muted}" FontSize="10"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="6,0,0,4"
                                           ToolTip="{Binding PreviewGroupsSummary}">
                                    <Run Text="{Binding PreviewModelInfo, Mode=OneWay}"/><LineBreak/>
                                    <Run Text="Ctrl+click a spot to locate it on the texture" Foreground="#FF29B6F6"/>
                                </TextBlock>
                                <!-- Hover-to-identify: which texture the part under the cursor uses -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="6" Padding="7,4" CornerRadius="3"
                                        Background="#D0111827" BorderBrush="{StaticResource Border.Muted}" BorderThickness="1"
                                        IsHitTestVisible="False" MaxWidth="520"
                                        Visibility="{Binding HoverTexture, Converter={StaticResource NonEmptyToVisibility}}">
                                    <TextBlock Text="{Binding HoverTexture}" Foreground="{StaticResource Fg.Primary}" FontSize="11" TextWrapping="Wrap"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,4,4,0">
                                    <Button Content="✎ Edit source" Padding="8,2" Command="{Binding OpenSourceTexturesCommand}"
                                            ToolTip="Open the source texture(s) in your image editor (temp copies) to reference or grab parts"/>
                                    <Button Content="⟳ Refresh" Padding="8,2" Margin="6,0,0,0" Command="{Binding RefreshPreviewCommand}"
                                            ToolTip="Reload the preview after editing the texture externally"/>
                                    <Button Content="⧉ Open in viewer" Padding="8,2" Margin="6,0,0,0" Click="OpenInViewer_Click"
                                            ToolTip="Export this model + your textures and open it in an external viewer (e.g. P3D Analyzer) for a game-faithful render. You'll be asked for the viewer's .exe the first time."/>
                                </StackPanel>
                                <!-- UV debug: flip/rotate/shift the texture on the preview to find the mapping that
                                     matches the in-game look. Diagnostic only; does not change the packed mod. -->
                                <Expander VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,6,20"
                                          Header="UV debug" Foreground="{StaticResource Fg.Muted}" FontSize="11"
                                          ToolTip="Experiment with the texture mapping on the preview. This does NOT affect the packed mod — it only helps diagnose the 3D preview.">
                                    <Border Background="#E0111827" BorderBrush="{StaticResource Border.Muted}" BorderThickness="1"
                                            CornerRadius="3" Padding="8">
                                        <StackPanel Width="230">
                                            <StackPanel Orientation="Horizontal">
                                                <CheckBox Content="Flip U" IsChecked="{Binding UvFlipU}" Foreground="{StaticResource Fg.Primary}"/>
                                                <CheckBox Content="Flip V" IsChecked="{Binding UvFlipV}" Foreground="{StaticResource Fg.Primary}" Margin="14,0,0,0"/>
                                                <Button Content="Rotate 90°" Command="{Binding UvRotateCommand}" Padding="6,1" Margin="14,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="Offset U" Foreground="{StaticResource Fg.Muted}" FontSize="10" Margin="0,8,0,0"/>
                                            <Slider Minimum="-1" Maximum="1" SmallChange="0.01" LargeChange="0.05" Value="{Binding UvOffsetU}"/>
                                            <TextBlock Text="Offset V" Foreground="{StaticResource Fg.Muted}" FontSize="10"/>
                                            <Slider Minimum="-1" Maximum="1" SmallChange="0.01" LargeChange="0.05" Value="{Binding UvOffsetV}"/>
                                            <Grid Margin="0,6,0,0">
                                                <TextBlock Text="{Binding UvXformSummary}" Foreground="{StaticResource Fg.Primary}"
                                                           FontSize="10" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                <Button Content="Reset" Command="{Binding UvResetXformCommand}" Padding="8,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Separator Margin="0,8,0,6" Background="{StaticResource Border.Muted}"/>
                                            <CheckBox Content="Wear UV coordinate grid" IsChecked="{Binding DiagnosticGrid}"
                                                      Foreground="{StaticResource Fg.Primary}"
                                                      ToolTip="Dress the model in a labelled u,v grid so you can see exactly which texture coordinate lands on each body part — and compare it against the game to prove placement is faithful."/>
                                            <Button Content="⊞ Export UV grid (PNG)…" Command="{Binding ExportDiagnosticGridCommand}" Padding="6,3" Margin="0,4,0,0"
                                                    ToolTip="Save the labelled grid; wear it in-game (Arsenal) or open it in a viewer and compare which cell lands where vs this preview."/>
                                            <Button Content="⬒ Export UV map…" Command="{Binding ExportUvMapCommand}" Padding="6,3" Margin="0,4,0,0"
                                                    ToolTip="Save the model's UV layout as a transparent PNG. Open it as a layer over your texture in your image editor to paint decals onto the exact right spot (knee pads, chest, etc.)."/>
                                        </StackPanel>
                                    </Border>
                                </Expander>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Retexture actions card (project identity now lives in the top project bar) -->
                    <Border Grid.Row="2" Margin="0,4,0,0" Padding="10" CornerRadius="4"
                            Background="{StaticResource Bg.Toolbar}" BorderBrush="{StaticResource Border.Muted}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Add to project" Style="{StaticResource Heading}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="Retexture selected asset →" Padding="10,4"
                                        Command="{Binding RetextureSelectedCommand}"/>
                                <Button Content="Retexture all listed" Padding="10,4" Margin="8,0,0,0"
                                        Command="{Binding RetextureAllListedCommand}"
                                        ToolTip="Add every asset currently shown (after filtering) to the project"/>
                            </StackPanel>
                            <CheckBox Content="Copy source values (armor/stats)"
                                      IsChecked="{Binding CopySourceValues}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Horizontal splitter between the browse/preview row and the config row -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="{StaticResource Border.Muted}" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

            <!-- ROW 2: Retextures-in-project list (left) | config.cpp editor (right) -->
            <Grid Grid.Row="2" Margin="6,2,6,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" MinWidth="240"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2.4*" MinWidth="360"/>
                </Grid.ColumnDefinitions>

                <!-- Retextures in project: rich list + per-entry actions (now full-height on the left) -->
                <DockPanel Grid.Column="0">
                    <TextBlock DockPanel.Dock="Top" Text="Retextures in project" Style="{StaticResource Heading}"
                               VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <!-- Action buttons (rename now lives in the Editor form on the right) -->
                    <UniformGrid DockPanel.Dock="Bottom" Rows="1" Columns="3" Margin="0,6,0,0">
                        <Button Content="Edit" Margin="0,0,3,0" Command="{Binding EditEntryTexturesCommand}"
                                ToolTip="Open this retexture's .paa(s) in your default editor (GIMP/Photoshop)"/>
                        <Button Content="Duplicate" Margin="3,0,3,0" Command="{Binding DuplicateEntryCommand}"
                                ToolTip="Copy this retexture to a new class (shares the same texture files)"/>
                        <Button Content="Remove" Margin="3,0,0,0" Command="{Binding RemoveEntryCommand}"
                                ToolTip="Remove the selected retexture (Del)"/>
                    </UniformGrid>
                    <ListBox ItemsSource="{Binding ProjectEntries}" SelectedItem="{Binding SelectedEntry}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding RemoveEntryCommand}"/>
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <!-- ⚠ badge when a texture file is missing on disk -->
                                    <TextBlock DockPanel.Dock="Right" Text="⚠" FontSize="13" Margin="6,0,0,0"
                                               VerticalAlignment="Center" Foreground="{StaticResource Accent.Warn}"
                                               ToolTip="One or more texture files for this retexture are missing on disk"
                                               Visibility="{Binding HasMissingTexture, Converter={StaticResource BoolToVisibility}}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding NewClassName}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="{StaticResource Bg.Chip}" CornerRadius="3" Padding="4,0" Margin="0,1,6,1">
                                                <TextBlock Text="{Binding Category}" Foreground="{StaticResource Fg.Primary}" FontSize="10"/>
                                            </Border>
                                            <TextBlock Foreground="{StaticResource Fg.Muted}" FontSize="11" VerticalAlignment="Center"
                                                       Text="{Binding SelectionCount, StringFormat={}{0} selection(s)}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="4" VerticalAlignment="Stretch" Margin="6,0,6,0"/>

                <!-- Editor (form) | config.cpp tabs, with shared project action buttons above -->
                <DockPanel Grid.Column="2">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                        <Button Content="Regenerate" Width="112" Height="30" Command="{Binding RegenerateConfigCommand}"
                                ToolTip="Rebuild config.cpp from the project (keeps displayName + copied values) — Ctrl+R"/>
                        <Button Content="Save config" Width="112" Height="30" Margin="8,0,0,0" Command="{Binding SaveConfigCommand}"
                                ToolTip="Save the editor's config.cpp (Ctrl+S)"/>
                        <Button Content="Pack @Mod" Width="112" Height="30" Margin="8,0,0,0" Command="{Binding PackCommand}"
                                ToolTip="Build a loadable @mod folder (Ctrl+Shift+P)"/>
                        <Button Content="Open folder" Width="112" Height="30" Margin="8,0,0,0" Command="{Binding OpenProjectFolderCommand}"/>
                    </StackPanel>

                    <TabControl SelectedIndex="{Binding EditorTabIndex}" Background="{StaticResource Bg.Panel}"
                                BorderBrush="{StaticResource Border.Muted}" BorderThickness="1">
                        <!-- ============ FORM EDITOR ============ -->
                        <TabItem Header="Editor">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Bg.Panel}" Padding="10">
                                <StackPanel>
                                    <!-- Selected retexture -->
                                    <TextBlock Text="Selected retexture" Style="{StaticResource Heading}" Margin="0,0,0,6"/>
                                    <Grid IsEnabled="{Binding SelectedEntry, Converter={StaticResource NotNullToBool}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Class name" VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" VerticalContentAlignment="Center"
                                                 Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="The generated class name for this retexture"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Apply" Width="64" Margin="6,0,0,6"
                                                Command="{Binding RenameEntryCommand}" ToolTip="Rename the class (updates config)"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Display name" VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,6" VerticalContentAlignment="Center"
                                                 Text="{Binding FormDisplayName, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="Name shown in Arsenal (commits when you click away)"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Source class" VerticalAlignment="Center" Margin="0,0,10,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,4" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Fg.Muted}" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding SelectedEntry.SourceClass}"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Source model" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Fg.Muted}" TextTrimming="CharacterEllipsis"
                                                   Text="{Binding SelectedEntry.SourceModel}"/>
                                    </Grid>

                                    <!-- Selections + their textures -->
                                    <TextBlock Text="Textures" Style="{StaticResource Heading}" Margin="0,14,0,6"/>
                                    <ItemsControl ItemsSource="{Binding FormSelections}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Border.Muted}" BorderThickness="0,0,0,1" Padding="0,0,0,6" Margin="0,0,0,6">
                                                    <DockPanel>
                                                        <Button DockPanel.Dock="Right" Content="Browse…" Width="76" VerticalAlignment="Center"
                                                                Command="{Binding BrowseCommand}" ToolTip="Assign a .paa file to this selection"/>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding ProjectTexture}" Foreground="{StaticResource Fg.Primary}"
                                                                       FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SourceTexture, StringFormat=source: {0}}" Foreground="{StaticResource Fg.Muted}"
                                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding ProjectMaterial}" Foreground="{StaticResource Accent.Ok}"
                                                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding HasMaterial, Converter={StaticResource BoolToVisibility}}"
                                                                       ToolTip="This selection also swaps an .rvmat material (auto-copied and repointed)"/>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="(select a retexture on the left to edit it)" Foreground="{StaticResource Fg.Muted}" FontSize="11"
                                               Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisibility}}"/>

                                    <!-- Project settings -->
                                    <TextBlock Text="Project" Style="{StaticResource Heading}" Margin="0,18,0,6"/>
                                    <Grid IsEnabled="{Binding CurrentProjectPath, Converter={StaticResource NonEmptyToBool}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Author" VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" VerticalContentAlignment="Center"
                                                 Text="{Binding FormAuthor, UpdateSourceTrigger=LostFocus}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Prefix" VerticalAlignment="Center" Margin="0,0,10,6"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" VerticalContentAlignment="Center"
                                                 Text="{Binding FormPrefix, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="$PBOPREFIX$ — the in-game path of this addon"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="requiredAddons" VerticalAlignment="Top" Margin="0,2,10,0"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" MinHeight="54" AcceptsReturn="True" TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding FormRequiredAddons, UpdateSourceTrigger=LostFocus}"
                                                 ToolTip="One addon per line"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ============ config.cpp ============ -->
                        <TabItem Header="config.cpp">
                            <avalonedit:TextEditor x:Name="ConfigEditor"
                                     local:AvalonEditBehaviour.BindableText="{Binding ConfigText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" FontSize="12"
                                     ShowLineNumbers="True" WordWrap="False"
                                     HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource Bg.Panel}" Foreground="{StaticResource Fg.Primary}"
                                     LineNumbersForeground="{StaticResource Line.Numbers}"/>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
