<Application x:Class="ReTex.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ReTex.App.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:FileNameConverter x:Key="FileNameConverter"/>
            <conv:StatusSeverityToBrushConverter x:Key="StatusSeverityToBrush"/>
            <conv:ProjectPathToNameConverter x:Key="ProjectPathToName"/>
            <conv:NotNullToBoolConverter x:Key="NotNullToBool"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <conv:NonEmptyToBoolConverter x:Key="NonEmptyToBool"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisibility"/>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
