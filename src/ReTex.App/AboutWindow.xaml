<Window x:Class="ReTex.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ReTex" Height="360" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg.Status}">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Close" Width="90" IsCancel="True" IsDefault="True" Click="Close_Click"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="ReTex" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Fg.Primary}"/>
            <TextBlock Text="Arma 3 Retexture Studio" Foreground="{StaticResource Fg.Status}" Margin="0,2,0,0"/>
            <TextBlock x:Name="VersionText" Foreground="{StaticResource Fg.Muted}" FontSize="12" Margin="0,2,0,0"/>

            <Separator Margin="0,14" Background="{StaticResource Border.Muted}"/>

            <TextBlock Text="Getting started" FontWeight="Bold" Foreground="{StaticResource Fg.Primary}"/>
            <TextBlock Foreground="{StaticResource Fg.Primary}" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="18">
                1. Point ReTex at your Workshop / mods folder (Settings), then Scan.<LineBreak/>
                2. Pick a mod, then an asset. Tick the selections to retexture.<LineBreak/>
                3. "Retexture selected asset" copies its textures into a project.<LineBreak/>
                4. "Edit" opens the .paa in your image editor; paint and save, then Refresh.<LineBreak/>
                5. "Pack @Mod" builds a loadable @mod folder (needs pboc.exe).
            </TextBlock>
        </StackPanel>
    </DockPanel>
</Window>
